# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Packaging and distribution
build/
dist/
*.egg-info/
.eggs/

# Test and coverage outputs
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# Build/test tooling caches
.tox/
.nox/

# Runtime logs and temporary files
*.log
*.tmp

# Local model artifacts (generated locally)
models/*.pkl
models/*.joblib

# Notebook checkpoints
.ipynb_checkpoints/

# IDE/editor settings
.vscode/
.idea/

# macOS system files
.DS_Store

# Local environment files
.env
.env.*
!.env.example
